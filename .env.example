# Firebase — copy values from your Firebase project console
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

EXPO_PUBLIC_USE_EMULATOR=false

# Mapbox public token for the AllTrails-style outdoors basemap. Create one (free
# tier) at https://account.mapbox.com/access-tokens/. Without it, the app falls
# back to OpenStreetMap tiles (fine for dev, not for production).
#
# This is for LOCAL dev only. Cloud (EAS) builds read it from an EAS environment
# variable instead of eas.json, so it stays out of git:
#   eas env:list preview
#   eas env:create --name EXPO_PUBLIC_MAPBOX_TOKEN --value "pk...." \
#     --visibility sensitive --environment development --environment preview \
#     --environment production
# To rotate: revoke in the Mapbox dashboard, update this .env, and re-create the
# EAS variable with --force.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
# Host the app uses to reach the Firebase emulators. Leave unset to auto-pick:
# 'localhost' on the iOS simulator, '10.0.2.2' on the Android emulator. Set this to
# your dev machine's LAN IP (e.g. 192.168.1.50) when running on a PHYSICAL device.
# EXPO_PUBLIC_EMULATOR_HOST=192.168.1.50

# Twilio (set these in Firebase Functions environment config, not here)
# firebase functions:config:set twilio.sid="ACXXXXXX" twilio.token="XXXXXX" twilio.from="+1XXXXXXXXXX"
