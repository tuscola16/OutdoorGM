# Firebase web app config — from Firebase console → Project settings →
# "Your apps" → Add app → Web. These are NOT secrets (they ship in the client
# bundle); access is controlled by Firestore security rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=outdoor-gm.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=outdoor-gm
VITE_FIREBASE_STORAGE_BUCKET=outdoor-gm.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public Mapbox access token (pk....). The same token used by the mobile app's
# EXPO_PUBLIC_MAPBOX_TOKEN. Create one at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# Set to "true" to point auth/firestore/functions at local Firebase emulators
# (firebase emulators:start --config firebase.emulator.json).
VITE_USE_EMULATOR=false
