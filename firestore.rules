rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function memberPath(gameId) {
      return /databases/$(database)/documents/games/$(gameId)/members/$(request.auth.uid);
    }

    function isGameMember(gameId) {
      return isSignedIn() && exists(memberPath(gameId));
    }

    function isGameGM(gameId) {
      return isSignedIn()
        && exists(memberPath(gameId))
        && get(memberPath(gameId)).data.role == 'gm';
    }

    // Users can read/write their own profile only.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Collection-group read for the "my games" / account-deletion query
    // (collectionGroup('members').where('userId','==',uid)). A rule on the
    // explicit games/{gameId}/members/{memberId} path governs single-document
    // reads but does NOT authorize a collection-GROUP query — that requires a
    // recursive-wildcard match on the collection group. This grants a user read
    // access to their own membership docs wherever they live, which is exactly
    // what the query needs (and no more).
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Games
    match /games/{gameId} {
      // The game doc holds the secret join codes (playerCode/gmCode), so only
      // members may read it. New joiners never read it directly — they call the
      // joinGameByCode Cloud Function, which resolves the code server-side.
      allow read: if isGameMember(gameId);

      // Games are created only via the createGame Cloud Function (admin SDK),
      // which also generates secure codes and creates the creator's GM membership.
      allow create: if false;
      allow delete: if false;

      // Only GMs may update the game, and only the gameplay fields — never the
      // join codes or creatorId. hasOnly() rejects a write that touches any key
      // outside this set (and affectedKeys() lists only *changed* keys, so codes
      // and creatorId are protected because changing them isn't permitted here).
      allow update: if isGameGM(gameId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['name', 'phase', 'status', 'rules', 'boundary', 'config', 'startedAt', 'endedAt', 'gameDate', 'isTest', 'testStepIndex']);

      // Checkpoints — GM only. Players intentionally cannot see checkpoint
      // locations (it would reveal the objectives), so reads are GM-scoped too.
      match /checkpoints/{checkpointId} {
        allow read, write: if isGameGM(gameId);
      }

      // Runbook (#60) — the behavior attached to checkpoints (effects, triggers,
      // priorities). GM-only: it holds the secret payloads players must never see.
      // Cloud Functions (geofence resolution, fireRunbookEntry) read it via the admin
      // SDK and bypass these rules.
      match /runbook/{entryId} {
        allow read, write: if isGameGM(gameId);
      }

      // Members
      match /members/{memberId} {
        // GMs see the full roster (names, emails, tokens). Everyone else may read
        // only their own membership doc — players never read other members.
        allow read: if isGameGM(gameId) || (isSignedIn() && request.auth.uid == memberId);
        // NOTE: the collection-group "my games" query (where userId == uid) is
        // authorized by the recursive-wildcard `/{path=**}/members/{memberId}`
        // rule above — a nested-path rule here does not apply to group queries.

        // Members are created only by Cloud Functions (createGame / joinGameByCode)
        // so role can never be self-assigned by a client.
        allow create: if false;

        // A GM may promote/demote/edit any member. A user may update their OWN
        // member doc (mark out, refresh fcmToken, rename) but never change role,
        // userId, or district — that closes the privilege-escalation path and keeps
        // tribute pairing (district, #10) GM-assigned only. They also can't forge an
        // SOS acknowledgement (sosAckAt is GM-write-only, #5): a self-update may leave
        // it unchanged or reset it to null (raising a fresh SOS), never set a timestamp.
        allow update: if isGameGM(gameId)
          || (isSignedIn()
              && request.auth.uid == memberId
              && request.resource.data.role == resource.data.role
              && request.resource.data.userId == resource.data.userId
              && request.resource.data.get('district', null) == resource.data.get('district', null)
              && (request.resource.data.get('sosAckAt', null) == resource.data.get('sosAckAt', null)
                  || request.resource.data.get('sosAckAt', null) == null));

        // A GM may remove anyone; a user may remove their own membership (leave /
        // delete account).
        allow delete: if isGameGM(gameId) || (isSignedIn() && request.auth.uid == memberId);
      }

      // Locations — a player writes only their own doc, and only while they are an
      // active member of the game (so a removed/kicked player can no longer upload).
      match /locations/{userId} {
        allow read: if isGameGM(gameId) || (isSignedIn() && request.auth.uid == userId);
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && isGameMember(gameId)
          && request.resource.data.userId == userId
          && request.resource.data.latitude is number
          && request.resource.data.longitude is number
          && request.resource.data.latitude >= -90 && request.resource.data.latitude <= 90
          && request.resource.data.longitude >= -180 && request.resource.data.longitude <= 180;
        allow delete: if isGameGM(gameId) || (isSignedIn() && request.auth.uid == userId);
      }

      // Arrivals — written only by Cloud Functions (admin SDK). Readable by GMs
      // only; arrival records contain other players' positions.
      match /arrivals/{arrivalId} {
        allow read: if isGameGM(gameId);
        allow write: if false;
      }

      // Broadcasts — GM→player one-way messages (Rule 23: no player↔player comms).
      // Players read global messages (targetPlayerId == null) + ones aimed at them.
      // Only GMs write; Cloud Functions (death/winner/checkpoint events) use the
      // admin SDK and bypass rules.
      match /broadcasts/{broadcastId} {
        // Players read global + own-targeted messages, but never co-GM messages (#40):
        // those carry audience:'gm-only' (and the GM_BROADCAST_TARGET sentinel, which a
        // player's targetPlayerId queries already exclude — the audience check is
        // defense-in-depth). GMs read everything.
        allow read: if isGameGM(gameId)
          || (isSignedIn()
              && resource.data.get('audience', null) != 'gm-only'
              && (resource.data.targetPlayerId == null
                  || resource.data.targetPlayerId == request.auth.uid));
        allow create, update, delete: if isGameGM(gameId);
      }

      // Run-sheet (#11) — GM-authored timed actions. GM read/write; players never
      // read it (they only see the broadcasts it produces). Cloud Functions (admin
      // SDK) stamp firedAt + execute actions, bypassing rules.
      match /scheduledEvents/{eventId} {
        allow read, write: if isGameGM(gameId);
      }

      // Rations — a player writes only their own submission (doc id `${uid}_${n}`)
      // and only while it's still pending; the GM reviews (sets status). A player
      // can never mark their own ration valid.
      match /rations/{rationId} {
        allow read: if isGameGM(gameId)
          || (isSignedIn() && resource.data.playerId == request.auth.uid);
        allow create: if isSignedIn()
          && isGameMember(gameId)
          && request.resource.data.playerId == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.intervalIndex is int
          && request.resource.data.photoUrl is string;
        allow update: if isGameGM(gameId)
          || (isSignedIn()
              && request.auth.uid == resource.data.playerId
              && resource.data.status == 'pending'
              && request.resource.data.status == 'pending');
        allow delete: if isGameGM(gameId);
      }

      // Per-player/per-checkpoint crossing latch (#50/#55). Written only by Cloud
      // Functions (admin SDK); never readable or writable by clients. Tracks inside/
      // outside state, streak count, and last-notified state for debouncing + re-notify.
      match /checkpointTrips/{tripId} {
        allow read, write: if false;
      }

      // Per-player/per-runbook-entry trip latch (#67). Written only by Cloud Functions
      // (admin SDK); never readable or writable by clients. Existence = the player has
      // already tripped that entry, so each entry fires at most once per player.
      match /entryTrips/{entryTripId} {
        allow read, write: if false;
      }

      // Revealed checkpoint markers (#48) — the player-readable projection of a
      // checkpoint's label + location once it's visible. The `checkpoints` collection
      // stays GM-only (it holds coords + the secret event payload); this is the only
      // checkpoint data a player ever sees. A player reads a marker if it's global
      // (audiencePlayerIds null/absent) or names them (case A trap / case D sponsor).
      // GMs may write (e.g. "reveal now"); Cloud Functions use the admin SDK and bypass.
      // The `||` short-circuits so `in` is never evaluated against a null audience.
      match /markers/{markerId} {
        allow read: if isGameGM(gameId)
          || (isSignedIn()
              && (resource.data.get('audiencePlayerIds', null) == null
                  || request.auth.uid in resource.data.audiencePlayerIds));
        allow write: if isGameGM(gameId);
      }
    }
  }
}
